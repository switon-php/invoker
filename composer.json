{
  "name": "switon/invoker",
  "description": "Method invocation orchestration for Switon Framework",
  "type": "library",
  "keywords": [
    "switon",
    "invoker",
    "dispatch",
    "reflection"
  ],
  "homepage": "https://github.com/switon-php/invoker",
  "license": "MIT",
  "authors": [
    {
      "name": "switon",
      "email": "admin@switon.dev"
    }
  ],
  "support": {
    "source": "https://github.com/switon-php/invoker",
    "issues": "https://github.com/switon-php/invoker/issues",
    "docs": "https://docs.switon.dev/latest/invoker"
  },
  "require": {
    "php": ">=8.3",
    "switon/core": "^1.0",
    "switon/di": "^1.0"
  },
  "require-dev": {
    "switon/testing": "^1.0",
    "phpunit/phpunit": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "Switon\\Invoking\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Switon\\Invoking\\Tests\\": "tests/"
    }
  },
  "extra": {
    "switon": {
      "providers": [
        "Switon\\Invoking\\ServiceProvider"
      ]
    }
  }
}
